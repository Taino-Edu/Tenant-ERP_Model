{
  // =============================================================================
  // appsettings.Development.json — Configurações específicas de desenvolvimento
  // Sobrescreve appsettings.json quando ASPNETCORE_ENVIRONMENT=Development
  // IMPORTANTE: Use 'dotnet user-secrets' para dados sensíveis locais
  // =============================================================================

  "ConnectionStrings": {
    // Deixar vazio → usa SQLite automaticamente (sem PostgreSQL local)
    "PostgreSQL": ""
  },

  "MongoDbSettings": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "cardgamestore_cache"
  },

  "JwtSettings": {
    "SecretKey": "CardGameStore_SecretKey_2025_MinLength32Chars!",
    "Issuer": "http://localhost:5000",
    "Audience": "CardGameStore-Frontend",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 30
  },

  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  }
}
