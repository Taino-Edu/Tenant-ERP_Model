# =============================================================================
# .env.example — Copie para .env e preencha antes de subir com docker compose.
# NUNCA commite o arquivo .env no Git!
#
# Como gerar valores seguros:
#   JWT_SECRET:        openssl rand -base64 48
#   POSTGRES_PASSWORD: openssl rand -base64 24
# =============================================================================

# ---------------------------------------------------------------------------
# URL pública da API — usada pelo BROWSER para chamar a API e o SignalR.
# Desenvolvimento local:  http://localhost:5000
# Oracle VM (sem domínio): http://<IP_PUBLICO>:5000
# Produção com domínio:    https://api.seudominio.com.br
# ---------------------------------------------------------------------------
API_URL=http://localhost:5000

# ---------------------------------------------------------------------------
# JWT — chave secreta de assinatura dos tokens (mínimo 32 chars aleatórios)
# ---------------------------------------------------------------------------
JWT_SECRET=SUBSTITUA_POR_UMA_CHAVE_FORTE_COM_48_CHARS_ALEATORIOS

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=cardgame_user
POSTGRES_PASSWORD=SUBSTITUA_POR_UMA_SENHA_FORTE
POSTGRES_DB=cardgamestore

# ---------------------------------------------------------------------------
# TCG APIs (opcional)
# PokemonTCG.io — sem chave: ~1000 req/dia | com chave: sem limite
# Crie sua chave em: https://dev.pokemontcg.io/
# ---------------------------------------------------------------------------
POKEMON_API_KEY=

# ---------------------------------------------------------------------------
# Email (opcional — sistema funciona sem email em dev/testes)
# Gmail:    HOST=smtp.gmail.com PORT=587 USER=seu@gmail.com PASS=senha-de-app
# SendGrid: HOST=smtp.sendgrid.net PORT=587 USER=apikey PASS=SG.xxxxx
# Resend:   HOST=smtp.resend.com PORT=465 USER=resend PASS=re_xxxxx
# ---------------------------------------------------------------------------
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@softnerd.com.br
# URL base do frontend (usado no link de reset de senha nos emails)
APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Gemini AI — assistente conversacional no painel admin (opcional)
# Obtenha sua chave GRATUITA em: https://aistudio.google.com/apikey
# Limite free: 1.500 req/dia, 15 req/minuto (suficiente para uso normal)
# O sistema funciona sem essa chave — o chat mostrará mensagem amigável.
# ---------------------------------------------------------------------------
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# pgAdmin — apenas usado com: docker compose --profile tools up
# ---------------------------------------------------------------------------
PGADMIN_EMAIL=admin@cardgame.com
PGADMIN_PASSWORD=SUBSTITUA_POR_UMA_SENHA_FORTE

# Salt para hash de IP no audit log (gerar: openssl rand -base64 32)
SECURITY_IPHASHSALT=

# ---------------------------------------------------------------------------
# Cookie (false para HTTP/testes, true para HTTPS/produção)
# ---------------------------------------------------------------------------
COOKIE_SECURE=true
