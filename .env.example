# =============================================================================
# .env.example — Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no Git!
# =============================================================================

# Chave secreta JWT (mínimo 32 caracteres aleatórios)
# Gere uma: openssl rand -base64 32
JWT_SECRET=SUBSTITUA_POR_UMA_CHAVE_FORTE_E_ALEATORIA_COM_32_CHARS

# Banco de dados PostgreSQL
POSTGRES_USER=cardgame_user
POSTGRES_PASSWORD=SUBSTITUA_POR_UMA_SENHA_FORTE
POSTGRES_DB=cardgamestore

# pgAdmin (opcional)
PGADMIN_EMAIL=admin@seudominio.com
PGADMIN_PASSWORD=SUBSTITUA_POR_UMA_SENHA_FORTE
