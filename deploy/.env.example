# =============================================================================
# .env — Variáveis de produção Tenant-ERP
# IMPORTANTE: renomeie este arquivo para .env e preencha TODOS os valores
# NUNCA commite o arquivo .env no Git!
# =============================================================================

# -----------------------------------------------------------------------------
# Acesso (por padrão testa por IP puro, sem HTTPS)
# ATENÇÃO: assim que tiver domínio + Cloudflare configurados, troque APP_URL
# pra https://seu-dominio.com e COOKIE_SECURE pra true. Deixar false em
# produção com domínio ativo faz os cookies JWT trafegarem sem o flag Secure.
# A API loga um warning todo boot enquanto COOKIE_SECURE=false persistir.
# -----------------------------------------------------------------------------
APP_URL=http://TROQUE_PELO_IP_OU_DOMINIO
COOKIE_SECURE=false

# Domínio raiz dos subdomínios de tenant (ex: "2esysten.com.br" para que
# loja.2esysten.com.br resolva o tenant "loja"). Deixe vazio até o DNS
# wildcard estar configurado — sem isso tudo cai em tenant-zero.
MULTITENANCY_ROOT_DOMAIN=

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=cardgamestore
POSTGRES_USER=cardgame_user
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI   # ex: xK9#mPq2vL8@nR5

# -----------------------------------------------------------------------------
# JWT — chave secreta para assinar tokens de autenticação
# Gere com: openssl rand -base64 64
# -----------------------------------------------------------------------------
JWT_SECRET=TROQUE_POR_CHAVE_JWT_AQUI

# -----------------------------------------------------------------------------
# E-mail (Resend) — https://resend.com
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USERNAME=resend
SMTP_PASSWORD=re_XXXXXXXXXXXXXXXXXXXX    # API key do Resend
SMTP_FROM_EMAIL=noreply@tenant-erp.local
SMTP_FROM_NAME="Tenant ERP"

# -----------------------------------------------------------------------------
# Integrações
# -----------------------------------------------------------------------------
GEMINI_API_KEY=AIzaSy_XXXXXXXXXXXXXXXXXXXX

# Opcional — só pro botão "Enriquecer com IA" da Prospecção de leads
# (/plataforma/prospeccao). Pode reusar a mesma chave acima ou usar uma
# dedicada pra isolar custo/cota. Sem preencher, a busca continua funcionando
# normalmente, só o enriquecimento fica indisponível.
PROSPECTING_GEMINI_API_KEY=AIzaSy_XXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# WhatsApp por tenant (Evolution API) — feature premium, DESLIGADA por padrão.
# Os serviços estão atrás do profile "whatsapp" no docker-compose.prod.yml e só
# sobem com: docker compose -f docker-compose.prod.yml --profile whatsapp up -d
# -----------------------------------------------------------------------------
# Chave que protege a API da Evolution (gere uma aleatória: openssl rand -hex 24).
# Quem tiver esta chave controla TODAS as instâncias de WhatsApp — trate como senha.
EVOLUTION_API_KEY=
# URL pública pela qual a Evolution se enxerga (usada nos QR Codes e callbacks).
EVOLUTION_SERVER_URL=http://localhost:8080
# Webhook que recebe as mensagens. A API .NET resolve o tenant pelo nome da
# instância. Deixe ENABLED=false até o endpoint existir do outro lado.
EVOLUTION_WEBHOOK_URL=http://api:5000/api/whatsapp/webhook
EVOLUTION_WEBHOOK_ENABLED=false

# -----------------------------------------------------------------------------
# Segurança
# Gere com: openssl rand -hex 32
# -----------------------------------------------------------------------------
IP_HASH_SALT=TROQUE_POR_SALT_AQUI

# -----------------------------------------------------------------------------
# Criptografia de dados sensíveis em repouso (senha de certificado, client
# secrets do Inter/Mercado Pago, tokens OAuth) — AES-256-GCM.
# Gere com: openssl rand -base64 32
# NUNCA troque depois do primeiro deploy — tudo que já foi salvo criptografado
# com a chave antiga vira ilegível pra sempre (erro "authentication tag did
# not match" nos logs é exatamente isso). Faça backup deste valor.
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=TROQUE_POR_CHAVE_GERADA_AQUI
